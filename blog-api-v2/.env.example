# Copier ce fichier en .env et remplir les valeurs

# URI de connexion MongoDB (local ou MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/blogdb

# Port du serveur (Render utilise la variable PORT automatiquement)
PORT=3000

# URL de base de l'API (utilisée par Swagger)
# En local :
BASE_URL=http://localhost:3000
# Sur Render, mettre l'URL de ton app ex: https://blog-api-xxxx.onrender.com
